# Python caches and compiled files
__pycache__/
*.py[cod]
*$py.class

# Jupyter state and temporary exports
.ipynb_checkpoints/
*.nbconvert.ipynb
*.nbconvert.html
*.nbconvert_files/
.~*.ipynb

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*
!.env.example

# IDE and editor files
.idea/
.vscode/
*.code-workspace
*.swp
*~

# Operating-system files
.DS_Store
Thumbs.db
Desktop.ini

# Tests and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Type-checking and lint caches
.mypy_cache/
.ruff_cache/
.pytype/

# Local logs and temporary files
*.log
*.tmp
*.temp

# Raw and generated data; preserve directory markers and provenance metadata
data/raw/**
!data/raw/.gitkeep
!data/raw/**/
!data/raw/**/.gitkeep
!data/raw/**/*.md
!data/raw/**/source_metadata.json
data/interim/*
!data/interim/.gitkeep
!data/interim/*.md
data/processed/*
!data/processed/.gitkeep
!data/processed/*.md

